---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import CycleName from "../components/CycleName.astro";

const posts = await getCollection("posts");
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
---

<Layout home={true} title="Jeremiah Crowell">
  <section class="text-xl md:text-2xl py-5 space-y-3">
    <CycleName />
    <p>
      I'm a <span class="underline underline-offset-1 decoration-blue-500"
        >software developer</span
      > with a CS + Statistics background and a passion for machine learning and data
      science. I'm working at John Deere and completed a <span
        class="underline underline-offset-1 decoration-blue-500"
        >Master's of Data Science</span
      > at UIUC
    </p>
    <div class="py-4 flex justify-center space-x-20">
      <a class="cool-link" target="_blank" href="/jcrowell_resume.pdf"
        >⇒ Résumé</a
      >
      <a
        class="cool-link"
        target="_blank"
        href="mailto:jeremiah.c2001@gmail.com">⇒ Email</a
      >
    </div>
    <p>
      I also just generally like learning and making cool stuff. My other
      endeavours include...
    </p>
    <ul class="list-disc list-inside">
      <li>
        Building <a
          class="cool-link"
          target="_blank"
          href="https://www.boardally.io/">Boardally</a
        >
      </li>
      <li>Myriad side <a class="cool-link" href="/projects">projects</a></li>
      <li>
        Amateur <a
          class="cool-link"
          target="_blank"
          href="https://www.instagram.com/jay_cr0well/">astrophotography</a
        >
      </li>
    </ul>
  </section>

  <section class="py-5">
    <h1 class="text-3xl pb-3">Blog</h1>
    <ul>
      {
        sortedPosts.map((post) => (
          <li class="pb-4">
            <p class="text-2xl">
              <a class="cool-link" href={`/posts/${post.id}`}>
                {post.data.title}
              </a>
            </p>
            <p class="text-lg text-gray-600">
              <FormattedDate dateString={post.data.date} />
            </p>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
